<!-- Custom targeting reticle cursor — two concentric squares -->
<div id="cursor" class="cursor" aria-hidden="true">
  <div class="cursor-outer"></div>
  <div class="cursor-inner"></div>
</div>

<style>
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9999;
    pointer-events: none;
    mix-blend-mode: difference;
  }
  .cursor-outer,
  .cursor-inner {
    position: absolute;
    border: 1px solid var(--signal);
    transition: transform 0.15s var(--ease-out-expo), opacity 0.15s;
  }
  .cursor-outer {
    width: 28px;
    height: 28px;
    top: -14px;
    left: -14px;
    transform: rotate(45deg);
  }
  .cursor-inner {
    width: 8px;
    height: 8px;
    top: -4px;
    left: -4px;
  }
  /* Hide on touch devices */
  @media (hover: none), (pointer: coarse) {
    .cursor { display: none; }
  }
</style>

<script>
  import '../scripts/cursor';
</script>
