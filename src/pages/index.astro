---
import Layout from '../layouts/Layout.astro';
import BootSequence from '../components/BootSequence.astro';
import Nav from '../components/Nav.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Hero from '../components/Hero.astro';
import Mandate from '../components/Mandate.astro';
import Projects from '../components/Projects.astro';
import DependencyGraph from '../components/DependencyGraph.astro';
import Values from '../components/Values.astro';
import TheBuild from '../components/TheBuild.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import StateTransition from '../components/StateTransition.astro';
---
<Layout>
  <BootSequence />
  <Nav />
  <MobileMenu />
  <StateTransition />
  <Cursor />

  <main>
    <Hero />
    <Mandate />
    <Projects />
    <DependencyGraph />
    <Values />
    <TheBuild />
  </main>

  <Footer />
</Layout>

<script>
  import '../scripts/parallax';
</script>
